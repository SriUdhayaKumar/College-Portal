           <br><br>

           <lable>Year :</lable>
           <input type="number" name="year" required>
           <br><br>

           <label>Mark :</label>
           <input type="number" name="mark" required>
           <br><br>

           <button type="submit">Submit</button>
           </form>
        </div>
    </body>
</html>